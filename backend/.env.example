# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration - Múltiplas origens separadas por vírgula
CORS_ORIGINS=http://localhost:3000,https://elynce.com.br,https://www.elynce.com.br

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=prosipe-homolog
# Opcional: use DATABASE_URL se preferir manter a URL completa
# DATABASE_URL=postgresql://postgres:admin123@localhost:5432/prosipe-homolog?schema=public

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Brevo/Sendinblue)
SMTP_HOST=smtp-relay.sendinblue.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-api-key
EMAIL_FROM=noreply@yourapp.com

# Google OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_AI_API_KEY=your-google-client-secret-here
GROQ_AI_API_KEY=your-groq-client-secret-here

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Push Notifications (VAPID keys for Web Push API)
# ================================================
# VAPID (Voluntary Application Server Identification) keys are required
# for sending push notifications to browsers.
#
# To generate new keys, run:
#   npx web-push generate-vapid-keys
#
# The public key is shared with the frontend, the private key stays on the server.
# Once set, do NOT change these keys or existing subscriptions will stop working.
#
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# Encryption Key (AES-256-GCM)
# ================================
# Chave mestra para criptografia simétrica de dados sensíveis no banco
# (ex: senhas IMAP). Deve ter exatamente 32 bytes (64 caracteres hex).
#
# Para gerar uma chave segura, rode:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
APP_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here
